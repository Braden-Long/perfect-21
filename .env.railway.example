# Paste these into Railway's Variables tab. Railway supplies PORT automatically.
# The SQLite file must live under the Railway volume mounted at /data.
DB_PATH=/data/perfect21.db
PUBLIC_URL=https://playperfect21.com
TRUST_PROXY=1

# Generate with: openssl rand -base64 48
ADMIN_TOKEN=REPLACE_WITH_A_LONG_RANDOM_VALUE

# Optional account-recovery email (Resend free tier).
# Create a Resend API key after verifying mail.playperfect21.com.
SMTP_URL=smtps://resend:REPLACE_WITH_RESEND_API_KEY@smtp.resend.com:465
MAIL_FROM=Perfect 21 <recovery@mail.playperfect21.com>

# Optional cosmetic donation-goal tracking.
# This is the public receiving address only. Never enter a private key or seed.
HELIUS_API_KEY=REPLACE_WITH_HELIUS_API_KEY
SOLANA_TIP_ADDRESS=REPLACE_WITH_PUBLIC_SOLANA_ADDRESS
